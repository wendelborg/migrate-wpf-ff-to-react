<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!--
      Base URL of the React SPA. The WPF host loads each page as a route
      under this URL inside a WebView2 control. Typical values:

        Development (Vite dev server):  http://localhost:5173
        Production (deployed SPA):      https://apps.contoso.com/myapp
    -->
    <add key="ReactAppBaseUrl" value="http://localhost:5173" />
  </appSettings>
</configuration>
