<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props"
          Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>WpfReactHost</RootNamespace>
    <AssemblyName>WpfReactHost</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <ProjectTypeGuids>{60dc8134-eba5-43b8-bcc9-bb4bc16c2548};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <WarningLevel>4</WarningLevel>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xaml">
      <RequiredTargetFramework>4.0</RequiredTargetFramework>
    </Reference>
    <Reference Include="System.Xml" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Configuration" />
    <Reference Include="WindowsBase" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Include="App.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </ApplicationDefinition>

    <Page Include="MainWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Include="Hosting\PageWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>

    <Compile Include="App.xaml.cs">
      <DependentUpon>App.xaml</DependentUpon>
    </Compile>
    <Compile Include="MainWindow.xaml.cs">
      <DependentUpon>MainWindow.xaml</DependentUpon>
    </Compile>
    <Compile Include="Bridge\BridgeMessage.cs" />
    <Compile Include="Hosting\PageWindow.xaml.cs">
      <DependentUpon>PageWindow.xaml</DependentUpon>
    </Compile>
    <Compile Include="Hosting\WindowManager.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="packages.config" />
    <None Include="App.config" />
  </ItemGroup>

  <!-- Copy the React WebView build output into the bin folder at build time.
       The glob is re-evaluated on every build so files dropped into wwwroot
       by the copy-react-bundle script are picked up automatically. -->
  <ItemGroup>
    <Content Include="wwwroot\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2535.41" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />

  <!-- Automatically build the React WebView bundle and copy it into wwwroot
       before the C# compile step. This means developers only need to build
       the WPF project - no separate script run required, provided Node.js
       is installed. If npm is not on PATH the target is skipped with a
       warning so the build does not fail. -->
  <PropertyGroup>
    <ReactAppDir>$(MSBuildThisFileDirectory)..\..\react-app</ReactAppDir>
    <ReactBundleOutDir>$(MSBuildThisFileDirectory)wwwroot</ReactBundleOutDir>
  </PropertyGroup>

  <Target Name="BuildReactBundle"
          BeforeTargets="BeforeBuild"
          Inputs="$(ReactAppDir)\src\**\*;$(ReactAppDir)\public\**\*;$(ReactAppDir)\package.json;$(ReactAppDir)\vite.webview.config.ts"
          Outputs="$(ReactBundleOutDir)\pages.js">
    <Exec Command="where npm"
          ContinueOnError="true"
          IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="NpmExitCode" />
    </Exec>

    <Warning Condition=" '$(NpmExitCode)' != '0' "
             Text="npm not found on PATH. Skipping React bundle build. Run scripts\copy-react-bundle.ps1 manually, then rebuild." />

    <Message Condition=" '$(NpmExitCode)' == '0' "
             Text="Building React WebView bundle..."
             Importance="high" />

    <Exec Condition=" '$(NpmExitCode)' == '0' "
          Command="npm install"
          WorkingDirectory="$(ReactAppDir)"
          ConsoleToMSBuild="true" />

    <Exec Condition=" '$(NpmExitCode)' == '0' "
          Command="npm run build:webview"
          WorkingDirectory="$(ReactAppDir)"
          ConsoleToMSBuild="true" />

    <MakeDir Condition=" '$(NpmExitCode)' == '0' "
             Directories="$(ReactBundleOutDir)" />

    <ItemGroup Condition=" '$(NpmExitCode)' == '0' ">
      <_ReactBundleFiles Include="$(ReactAppDir)\dist-webview\**\*" />
      <_ReactShellFile Include="$(ReactAppDir)\public\shell.html" />
    </ItemGroup>

    <Copy Condition=" '$(NpmExitCode)' == '0' "
          SourceFiles="@(_ReactBundleFiles)"
          DestinationFiles="@(_ReactBundleFiles->'$(ReactBundleOutDir)\%(RecursiveDir)%(Filename)%(Extension)')" />

    <Copy Condition=" '$(NpmExitCode)' == '0' "
          SourceFiles="@(_ReactShellFile)"
          DestinationFolder="$(ReactBundleOutDir)" />
  </Target>
</Project>
